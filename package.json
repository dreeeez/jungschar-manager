{
  "name": "jungschar-bot",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:bot": "npm run dev --workspace=apps/bot",
    "dev:mini-app": "npm run dev --workspace=apps/mini-app",
    "build": "npm run build --workspaces",
    "db:generate": "supabase gen types typescript --local > packages/shared/database.types.ts"
  },
  "devDependencies": {
    "typescript": "^5.3.0"
  }
}
